# =============================================================================
# era — apps/web environment contract
# =============================================================================
# Copy this file to `.env.local` and fill in real values. Never commit secrets.
#
# TWO SECTIONS, ONE HARD RULE:
#   - SERVER-ONLY vars stay on the server. They are NEVER exposed to the
#     browser. Do not prefix them with NEXT_PUBLIC_ and do not reference them
#     in client components — doing so leaks them into the JS bundle.
#   - CLIENT-SAFE vars use the NEXT_PUBLIC_ prefix. Next.js inlines these into
#     the browser bundle at build time, so treat them as fully public. Put
#     nothing sensitive here.
# =============================================================================


# -----------------------------------------------------------------------------
# SERVER-ONLY — never sent to the browser
# -----------------------------------------------------------------------------

# Neon Postgres connection string (pooled)
DATABASE_URL=postgresql://user:password@host.neon.tech/era?sslmode=require

# Better Auth signing secret — 32+ random chars, rotate to invalidate sessions
BETTER_AUTH_SECRET=change-me-32-chars-min-random-secret

# Canonical app URL that Better Auth uses for callbacks
BETTER_AUTH_URL=http://localhost:3000

# Sign in with Apple — OAuth client ID
APPLE_OAUTH_CLIENT_ID=com.example.era.changeme

# Sign in with Apple — OAuth client secret
APPLE_OAUTH_CLIENT_SECRET=change-me-apple-oauth-secret

# Google OAuth — client ID
GOOGLE_OAUTH_CLIENT_ID=000000000000-changeme.apps.googleusercontent.com

# Google OAuth — client secret
GOOGLE_OAUTH_CLIENT_SECRET=change-me-google-oauth-secret

# Cloudflare R2 — account ID
R2_ACCOUNT_ID=change-me-r2-account-id

# Cloudflare R2 — access key ID
R2_ACCESS_KEY_ID=change-me-r2-access-key-id

# Cloudflare R2 — secret access key
R2_SECRET_ACCESS_KEY=change-me-r2-secret-access-key

# R2 bucket name for garment images
R2_BUCKET_GARMENTS=era-garments-dev

# R2 bucket name for user avatars
R2_BUCKET_AVATARS=era-avatars-dev

# Anthropic Claude API key — powers Ovi the stylist
ANTHROPIC_API_KEY=sk-ant-xxxx-change-me

# Garment recognition vision provider API key
VISION_API_KEY=change-me-vision-api-key

# Background removal provider API key
BG_REMOVAL_API_KEY=change-me-bg-removal-api-key

# Affiliate product feed key (Phase 2 — optional until Shop ships)
AFFILIATE_FEED_KEY=change-me-affiliate-feed-key


# -----------------------------------------------------------------------------
# CLIENT-SAFE — inlined into the browser bundle, treat as fully public
# -----------------------------------------------------------------------------

# API base URL the browser calls
NEXT_PUBLIC_API_URL=https://api.era.example.com

# Public CDN base for R2-hosted assets
NEXT_PUBLIC_R2_PUBLIC_URL=https://cdn.era.example.com
