{
  "expo": {
    "name": "Era",
    "slug": "era",
    "scheme": "era",
    "version": "0.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.era.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.era.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      ["@sentry/react-native/expo", { "url": "https://sentry.io/" }]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
