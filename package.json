{
  "name": "era",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "eval:models": "node --experimental-strip-types scripts/eval-models.ts",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "@era/core": "workspace:*",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0"
  }
}
